<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Logo -->
        <ImageView
            android:id="@+id/imgLoginLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/vpm_logo"
            android:contentDescription="@string/app_name"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="20dp" />

        <!-- Welcome Text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/welcome_back"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login_subtitle"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="32dp" />

        <!-- Username Input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_username"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etLoginUsername"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/edit_text_bg"
            android:hint="@string/hint_username"
            android:inputType="text"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"
            android:autofillHints="username" />

        <!-- Password Input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_password"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/etLoginPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/edit_text_bg"
            android:hint="@string/hint_password"
            android:inputType="textPassword"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"
            android:autofillHints="password" />

        <!-- ToggleButton - Show/Hide Password -->
        <ToggleButton
            android:id="@+id/toggleShowPassword"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:textOn="@string/toggle_hide_password"
            android:textOff="@string/toggle_show_password"
            android:textSize="12sp"
            android:layout_gravity="start"
            android:layout_marginBottom="24dp" />

        <!-- Login Button -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="@string/btn_login"
            android:background="@drawable/btn_rounded"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Navigate to Sign Up -->
        <TextView
            android:id="@+id/tvGoToSignUp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/new_user"
            android:textSize="14sp"
            android:textColor="@color/primary"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="32dp" />

        <!-- Divider Line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="16dp" />

        <!-- Device Settings Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_device_settings"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="12dp" />

        <!-- Sound Mode Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_sound_mode"
                android:textSize="14sp" />

            <ToggleButton
                android:id="@+id/toggleSoundMode"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:textOn="@string/toggle_loud"
                android:textOff="@string/toggle_silent"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Airplane Mode Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/card_bg"
            android:padding="12dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_airplane_mode"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvAirplaneStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/checking"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/primary" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>