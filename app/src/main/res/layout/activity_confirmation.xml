<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/vote_confirmation"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp" />

        <!-- Vote Details Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/vote_details_title"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="16dp" />

            <!-- Voter -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_voter"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvConfirmVoter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_voter"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/black" />
            </LinearLayout>

            <!-- Branch -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_branch"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvConfirmBranch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_na"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/black" />
            </LinearLayout>

            <!-- Events -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_events"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvConfirmEvents"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_na"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/black" />
            </LinearLayout>

            <!-- Candidate -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_candidate"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvConfirmCandidate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/default_na"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent" />
            </LinearLayout>
        </LinearLayout>

        <!-- Vote Converter Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/converter_title"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/converter_subtitle"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvConverterResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/converter_calculating"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/success_green"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvConverterDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- Progress Bar Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/submitting_title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="12dp" />

            <ProgressBar
                android:id="@+id/progressBarVote"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="16dp"
                android:max="100"
                android:progress="0"
                android:progressTint="@color/accent"
                android:progressBackgroundTint="#E0E0E0"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvProgressPercent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/progress_zero"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <!-- Countdown Display -->
            <TextView
                android:id="@+id/tvCountdownConfirm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/converter_calculating"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

        <!-- Success Message (hidden initially) -->
        <TextView
            android:id="@+id/tvSuccessMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/vote_success_message"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/success_green"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="24dp" />

        <!-- Visit Website Button (hidden initially) -->
        <Button
            android:id="@+id/btnVisitWebsite"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/btn_primary"
            android:text="@string/btn_visit_website"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Exit Button (hidden initially) -->
        <Button
            android:id="@+id/btnExit"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="@string/btn_exit"
            android:background="@drawable/btn_red"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>