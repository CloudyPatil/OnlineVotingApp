<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/vote_candidate"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginBottom="4dp" />

        <!-- Info Display -->
        <TextView
            android:id="@+id/tvVoteInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_branch"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp" />

        <!-- Instructions -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/vote_instructions"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp" />

        <!-- GridLayout with 4 Candidates in 2x2 grid -->
        <GridLayout
            android:id="@+id/gridLayoutCandidates"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false"
            android:useDefaultMargins="true"
            android:layout_marginBottom="8dp">

            <!-- CANDIDATE 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/candidate_border"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="12dp">

                <ImageButton
                    android:id="@+id/imgBtn1"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_candidate"
                    android:scaleType="centerCrop"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/candidate_1_name"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/candidate_1_name"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/candidate_1_desc"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <RadioButton
                    android:id="@+id/rb1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_vote"
                    android:textSize="12sp"
                    android:buttonTint="@color/accent" />
            </LinearLayout>

            <!-- CANDIDATE 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/candidate_border"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="12dp">

                <ImageButton
                    android:id="@+id/imgBtn2"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_candidate"
                    android:scaleType="centerCrop"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/candidate_2_name"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/candidate_2_name"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/candidate_2_desc"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <RadioButton
                    android:id="@+id/rb2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_vote"
                    android:textSize="12sp"
                    android:buttonTint="@color/accent" />
            </LinearLayout>

            <!-- CANDIDATE 3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/candidate_border"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="12dp">

                <ImageButton
                    android:id="@+id/imgBtn3"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_candidate"
                    android:scaleType="centerCrop"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/candidate_3_name"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/candidate_3_name"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/candidate_3_desc"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <RadioButton
                    android:id="@+id/rb3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_vote"
                    android:textSize="12sp"
                    android:buttonTint="@color/accent" />
            </LinearLayout>

            <!-- CANDIDATE 4 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/candidate_border"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="12dp">

                <ImageButton
                    android:id="@+id/imgBtn4"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_candidate"
                    android:scaleType="centerCrop"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/candidate_4_name"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/candidate_4_name"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/candidate_4_desc"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <RadioButton
                    android:id="@+id/rb4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_vote"
                    android:textSize="12sp"
                    android:buttonTint="@color/accent" />
            </LinearLayout>

        </GridLayout>

        <!-- GridView Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/gridview_title"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <GridView
            android:id="@+id/gridViewCandidates"
            android:layout_width="match_parent"
            android:layout_height="400dp"
            android:numColumns="2"
            android:horizontalSpacing="8dp"
            android:verticalSpacing="8dp"
            android:gravity="center"
            android:stretchMode="columnWidth"
            android:background="@drawable/card_bg"
            android:padding="8dp"
            android:layout_marginBottom="16dp" />

        <!-- Submit Vote Button -->
        <Button
            android:id="@+id/btnSubmitVote"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="@string/btn_submit_vote"
            android:background="@drawable/btn_rounded"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>